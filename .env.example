# Email Configuration for Password Reset
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-specific-password

# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/DatabaseName?retryWrites=true&w=majority

# JWT Secret - MUST be a long, random, secure string (minimum 32 characters)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_MINIMUM_32_CHARS

# Server Configuration
PORT=5001

# Client URL for CORS (production URL or localhost for development)
CLIENT_URL=http://localhost:3000

# Environment (development, production)
NODE_ENV=development
